// ============================================================================
// Comprehensive language stability test
// Exercises ALL syntax features across all phases
// ============================================================================

// ── Imports and modules ──
import "core/prelude";
module stability;

// ── Struct with pub fields ──
pub struct Matrix {
    pub rows: i32;
    pub cols: i32;
    data: []f64;
}

// ── Enum with variant data ──
pub enum Either {
    Left(i32),
    Right(string),
    Neither,
}

// ── Generic types ──
fn identity(val: i32) -> i32 {
    return val;
}

// ── Array literals ──
fn test_arrays() -> void {
    let nums = [1, 2, 3, 4, 5];
    let empty = [0];
}

// ── String and char handling ──
fn test_strings() -> void {
    let greeting: string = "Hello, World!";
    let escaped: string = "line1\nline2\ttab";
    let ch: char = 'X';
    let null_char: char = '\0';
}

// ── Complex expressions ──
fn test_expressions() -> i32 {
    let a: i32 = 10;
    let b: i32 = 20;

    // Operator precedence: * before +
    let c = a + b * 2;

    // Grouping
    let d = (a + b) * 2;

    // Boolean expressions
    let e: bool = a > 5 && b < 30;
    let f: bool = a == 10 || b == 10;

    // Nested calls
    let g = identity(identity(42));

    return c + d + g;
}

// ── Struct literal and member access ──
fn test_struct_ops() -> void {
    let m = Matrix { rows: 3, cols: 3, data: [0.0] };
    let r = m.rows;
    let c = m.cols;
}

// ── Match on enum ──
fn test_either(e: Either) -> i32 {
    match e {
        Either::Left => {
            return 1;
        }
        Either::Right => {
            return 2;
        }
        Either::Neither => {
            return 0;
        }
    }
}

// ── Impl block ──
impl Matrix {
    fn is_square(self) -> bool {
        return self.rows == self.cols;
    }

    fn element_count(self) -> i32 {
        return self.rows * self.cols;
    }
}

// ── Trait impl ──
impl Printable for Matrix {
    fn describe(self) -> string {
        return "matrix";
    }
}

trait Printable {
    fn describe(self) -> string {
        return "unnamed";
    }
}

// ── Nested control flow ──
fn fizzbuzz(n: i32) -> void {
    mut i: i32 = 1;
    while i <= n {
        if i % 15 == 0 {
            println("FizzBuzz");
        } else if i % 3 == 0 {
            println("Fizz");
        } else if i % 5 == 0 {
            println("Buzz");
        } else {
            println("number");
        }
        i += 1;
    }
}

// ── For loop ──
fn test_for_loop() -> i32 {
    mut total: i32 = 0;
    for i in 0..10 {
        total += 1;
    }
    return total;
}

// ── Reactor with arena ──
fn test_reactor() -> void {
    reactor arena(8192) {
        let buffer_size: i32 = 1024;
        println("Allocating in arena");
    }
}

// ── Try/catch/finally ──
fn test_exceptions() -> void {
    try {
        let x = 42;
        throw "test error";
    } catch (e: string) {
        println("caught");
    } finally {
        println("cleanup");
    }
}

// ── Spawn block ──
fn test_concurrency() -> void {
    spawn {
        println("async work");
    }
}

// ── Polyglot C block ──
fn test_c_interop() -> void {
    c {
        int x = 42;
    }
}

// ── Pointer types ──
fn test_pointers(p: ^i32) -> void {
    let deref = ^p;
}

// ── Assignment operators ──
fn test_assign_ops() -> void {
    mut x: i32 = 10;
    x += 5;
    x -= 3;
    x *= 2;
    x /= 4;
    x %= 3;
}

// ── Index expressions ──
fn test_indexing() -> void {
    let arr = [10, 20, 30];
    let first = arr[0];
}

fn main() -> i32 {
    test_strings();
    test_arrays();
    let result = test_expressions();
    test_struct_ops();
    let either_result = test_either(Either::Left);
    fizzbuzz(15);
    let loop_total = test_for_loop();
    test_reactor();
    test_exceptions();
    test_concurrency();
    test_c_interop();
    test_assign_ops();
    test_indexing();
    println("STABILITY: All language features verified!");
    return 0;
}
